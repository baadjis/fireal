// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Le Propriétaire (Utilisateur principal)

// prisma/schema.prisma

// ... gardez vos modèles User, Bien, Locataire existants ...
// Mais modifiez le modèle User pour qu'il ait la relation vers Account et Session

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  adresse        String?
  ville          String?
  codePostal     String?
  telephone      String?
  plan           String   @default("BASIC") // "BASIC", "PRO", "EXPERT"
  
  // Pour le plan PRO & EXPERT (Stripe Connect)
  stripeConnectedId String?  @unique 
  
  subscriptionId   String?
  
  accounts      Account[] // AJOUTER CECI
  sessions      Session[] // AJOUTER CECI
  biens         Bien[]
  createdAt     DateTime  @default(now())
}

// AJOUTER CE MODÈLE (Obligatoire pour Google)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// AJOUTER CE MODÈLE (Obligatoire pour les sessions)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// Ajoutez l'Enum pour les types de biens
enum TypeBien {
  STUDIO
  T1
  T2
  T3
  T4
  T5
  MAISON
  PARKING
  LOCAL_COMMERCIAL
}

model Bien {
  id             String      @id @default(cuid())
  nom            String      // Nom "amical" (ex: T3 Centre)
  type           TypeBien    @default(T2) // Type de logement
  adresse        String
  ville          String
  codePostal     String
  etage          Int?        // Etage (null si maison)
  numeroPorte    String?     // Numéro ou lettre sur la porte
  surface        Float?      // Surface en m² (Loi Carrez)
  description    String?     @db.Text
  
  proprietaire   User        @relation(fields: [proprietaireId], references: [id])
  proprietaireId String
  locataires     Locataire[]
  createdAt      DateTime    @default(now())
}

enum StatutContrat {
  BROUILLON        // Le bail est généré mais pas encore envoyé
  ATTENTE_SIGNATURE // Envoyé pour signature (en ligne ou manuelle)
  SIGNE            // Le contrat est signé mais le locataire n'est pas encore "en place"
  ACTIF            // Le bail est en cours (déclenche les quittances)
  TERMINE          // Le locataire est parti
}
// 3. Le Locataire
model Locataire {
  id             String      @id @default(cuid())
  nom            String
  prenom         String
  email          String      @unique
  telephone      String?
  
  // Détails financiers du bail
  loyerHC        Float       // Loyer Hors Charges
  charges        Float       // Montant des charges
  jourPaiement   Int         @default(1) // Jour du mois où le loyer est dû (ex: le 1er ou le 5)
  
  bien           Bien        @relation(fields: [bienId], references: [id])
  bienId         String
  stripeCustomerId String?     @unique 
  paiements      Paiement[]
  quittances     Quittance[] // Liste des quittances générées pour ce locataire
  active         Boolean     @default(true) // Pour savoir si le locataire est toujours là
  statut      StatutContrat @default(BROUILLON)
  methodeSign String?       // "MANUELLE" ou "EN_LIGNE"
  signatureId String? 
  archived    Boolean   @default(false)
  createdAt      DateTime    @default(now())
  
}

// 4. L'historique des Quittances/Avis d'échéance
model Quittance {
  id             String    @id @default(cuid())
  mois           Int       // 1 pour Janvier, 2 pour Février, etc.
  annee          Int       // 2024, 2025...
  type           String    // "AVIS_ECHEANCE" ou "QUITTANCE"
  status         String    // "ENVOYE" ou "PAYE"
  
  montantTotal   Float
  pdfUrl         String?   // Si vous stockez le PDF sur un service comme Uploadthing ou AWS S3
  
  locataire      Locataire @relation(fields: [locataireId], references: [id])
  locataireId    String
  
  createdAt      DateTime  @default(now())
}

model Paiement {
  id          String    @id @default(cuid())
  mois        Int       // 1-12
  annee       Int
  datePaiement DateTime @default(now())
  locataire   Locataire @relation(fields: [locataireId], references: [id])
  locataireId String

  @@unique([locataireId, mois, annee]) // Un seul paiement par mois pour un locataire
}